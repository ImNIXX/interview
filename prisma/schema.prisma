generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Candidate {
  id        String      @id @default(cuid())
  name      String
  email     String?
  resumeText String     @db.Text
  resumeFileName String
  createdAt DateTime    @default(now())
  interviews Interview[]
}

model Interview {
  id            String     @id @default(cuid())
  candidateId   String
  candidate     Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  duration      Int        // 30 or 60 minutes
  status        String     @default("pending") // pending, in_progress, completed
  totalScore    Float?
  maxScore      Float?
  feedbackSummary String?  @db.Text
  createdAt     DateTime   @default(now())
  completedAt   DateTime?
  questions     Question[]
}

model Question {
  id              String   @id @default(cuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  category        String   // theoretical, logical, tricky, hands_on
  questionText    String   @db.Text
  expectedAnswer  String   @db.Text
  difficulty      String   @default("medium") // easy, medium, hard
  orderIndex      Int
  // Evaluation fields
  status          String   @default("not_asked") // not_asked, correct, incorrect, partial
  partialPercent  Int?     // 0-100, only used when status is "partial"
  notes           String?  @db.Text
}
